{
  "name": "asmr-player",
  "version": "1.1.0",
  "description": "🎧 沉浸式同人音声播放器 — 支持 RJ 作品管理、双耳可视化、多格式字幕(VTT/LRC/SRT/ASS)、10段均衡器、独立声道控制与分支路线选择。Electron + React + TypeScript + Web Audio API",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "vite build && electron-builder --win nsis portable",
    "electron:dir": "vite build && electron-builder --dir",
    "pack": "vite build && electron-builder --win nsis"
  },
  "dependencies": {
    "music-metadata": "^11.14.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.1.0",
    "electron": "^35.7.5",
    "electron-builder": "^25.1.8",
    "tsx": "^4.23.0",
    "typescript": "^5.9.3",
    "vite": "^6.4.3",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.7",
    "wait-on": "^8.0.1"
  },
  "allowScripts": {
    "electron@35.7.5": true,
    "esbuild@0.28.1": true
  }
}
